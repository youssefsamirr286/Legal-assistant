# LLM provider: gemini | openai | deepseek
LLM_PROVIDER=gemini

# Google Gemini (primary free-tier option for capstone)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_SECONDS=60

# OpenAI GPT-4o (optional multi-provider comparison)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# DeepSeek (optional OpenAI-compatible alternative)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Agent graph safety limit
AGENT_MAX_ITERATIONS=6

# If OpenAI/DeepSeek hit quota/balance errors, answer with Gemini instead
AUTO_FALLBACK_TO_GEMINI=true

# HuggingFace (optional, improves embedding download rate limits)
# HF_TOKEN=your_hf_token_here
